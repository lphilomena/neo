Bootstrap: docker
From: ubuntu:22.04

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends         bash ca-certificates coreutils gawk grep         libgomp1 libstdc++6 procps tcsh zlib1g
    rm -rf /var/lib/apt/lists/*

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    exec /bin/bash -lc ""
