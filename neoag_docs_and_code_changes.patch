+def _run_netmhcpan_local(
+    pairs: list[tuple[str, str]],
+    out_xls: Path,
+    *,
+    netmhcpan_exe: str,
+) -> None:
+    from ..adapters.netmhcpan import parse_netmhcpan_local_stdout, write_netmhcpan_standard_xls
