+def _run_prime_batch(
+    batch_dir: Path,
+    peptides: list[str],
+    prime_alleles: list[str],
+    prime_exe: Path,
+    mixmhcpred: str | None,
+) -> Path:
+    import os
+    import subprocess
+
+    batch_dir.mkdir(parents=True, exist_ok=True)
+    pep_file = batch_dir / "peptides.txt"
+    with pep_file.open("w", encoding="utf-8") as fh:
+        for peptide in peptides:
+            fh.write(peptide + "\n")
+    raw_out = batch_dir / "prime_out.tsv"
+    cmd = [
+        str(prime_exe),
+        "-i",
+        str(pep_file),
+        "-o",
+        str(raw_out),
+        "-a",
+        ",".join(prime_alleles),
+    ]
+    if mixmhcpred:
+        cmd.extend(["-mix", mixmhcpred])
+    subprocess.run(cmd, check=True, cwd=batch_dir, env=os.environ.copy())
+    return raw_out
+
