+    if ctx.phased_vcf:
+        cmd.extend(["-p", str(ctx.phased_vcf.resolve())])
+    _run_cmd(cmd, work)
+    candidates = sorted(work.rglob("*aggregated*.tsv"))
+    if not candidates:
+        candidates = sorted(work.rglob("*.tsv"))
+    if not candidates:
+        raise FileNotFoundError(f"pvacseq finished but no aggregated TSV in {work}")
