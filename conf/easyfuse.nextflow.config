// neoag EasyFuse runner — enable Nextflow conda + EasyFuse profile flags
conda {
  enabled = true
  useMamba = true
  createOptions = '-y --yes'
  cacheDir = System.getenv("NXF_CONDA_CACHEDIR") ?: "./work/.nextflow_conda"
}

// Propagate non-interactive conda/mamba flags to Nextflow child processes.
env {
  CONDA_ALWAYS_YES = 'true'
  MAMBA_YES = '1'
}

profiles {
  conda {
    params.enable_conda = true
  }
}

process {
  errorStrategy = 'terminate'
  // Strip neoag conda env bins and repo tool shims so `conda activate` (next line in .command.run)
  // wins for `#!/usr/bin/env python` / `#!/usr/bin/env Rscript`. FusionCatcher needs Python 2.7
  // from its conda env; tools/fusioncatcher/bin shadows it with system Python 3.
  beforeScript = { task.conda ? 'export PATH="$(echo "${PATH}" | tr \':\' \'\\n\' | grep -vE \'/envs/neoag-[^/]+/bin$|/tools/fusioncatcher/bin$\' | paste -sd: -)"; ulimit -s unlimited 2>/dev/null || ulimit -s 65536' : '' }

  // Large RNA libraries (~14GB trimmed fq) can segfault STAR 2.7.10a at 6 threads; 4 threads + more RAM is stable.
  withName: 'ALIGNMENT:STAR' {
    cpus = 4
    memory = '48 GB'
  }
  withName: 'REQUANTIFICATION:STAR_CUSTOM' {
    cpus = 4
    memory = '48 GB'
  }

  // STAR-Fusion can spend a long time parsing large Chimeric.out.junction files.
  withName: "TOOLS:STAR_FUSION" {
    cpus = 8
    memory = "64 GB"
    time = "24h"
  }

}
