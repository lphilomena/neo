params {
  profile_name = 'leukemia'
  sample_id = 'DEMO'
  outdir = 'results/nextflow_demo'

  pvac_files = "${projectDir}/data/fixtures/pvacseq_aggregated.tsv,${projectDir}/data/fixtures/pvacfuse_aggregated.tsv"
  netmhcpan = "${projectDir}/data/fixtures/netmhcpan_example.xls"
  mhcflurry = "${projectDir}/data/fixtures/mhcflurry_predictions.csv"
  vep_appm = "${projectDir}/data/fixtures/vep_appm.tsv"
  expression = "${projectDir}/data/fixtures/gene_expression.tsv"
  hla_loh = "${projectDir}/data/fixtures/hla_loh.tsv"
  purity = "${projectDir}/data/fixtures/purity.tsv"
  cnv = "${projectDir}/data/fixtures/cnv_segments.tsv"
  normal_expression = "${projectDir}/resources/normal_expression.example.tsv"
  normal_hla_ligands = "${projectDir}/resources/normal_hla_ligands.example.tsv"
}

process {
  executor = 'local'
  errorStrategy = 'terminate'
}
