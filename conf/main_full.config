/*
 * main_full.nf — Companion Configuration
 *
 * End-to-end full pipeline: upstream tools (pVAC/NetMHCpan/MHCflurry/VEP) +
 * scoring chain + report.  Mirrors `neoag-v03 run-full` behaviour.
 *
 * Usage (demo / quickstart — matches tests/run_demo/run_demo.sh):
 *   bin/neoag-nextflow run workflows/main_full.nf \
 *     --run_config tests/run_demo/run.sliding.private.toml \
 *     -c conf/main_full.config
 *
 * Usage (stub mode for CI / dry-run):
 *   bin/neoag-nextflow run workflows/main_full.nf \
 *     -c conf/main_full.config
 *
 * Production (HPC):
 *   bin/neoag-nextflow run workflows/main_full.nf \
 *     --run_config conf/run.private.toml \
 *     -c conf/main_full.config -profile slurm
 *
 * Production (containers):
 *   NEOAG_RUNNER_MODE=docker \
 *   bin/neoag-nextflow run workflows/main_full.nf \
 *     --run_config conf/run.private.toml \
 *     -c conf/main_full.config -profile standard
 */

params {
  // --- Sample & scoring (defaults; overridden by TOML [sample] section) ------
  profile_name = 'default'
  outdir = 'results/full'

  // --- Upstream control ----------------------------------------------------
  run_config = "${launchDir}/conf/run.stub.toml"
  run_upstream_stub = false
  entry_mode = 'snv_indel'
  immunogenicity_stub = false

  // --- Resource paths (used when upstream doesn't produce these files) ------
  normal_expression = "${launchDir}/resources/normal_expression.example.tsv"
  normal_hla_ligands = "${launchDir}/resources/normal_hla_ligands.example.tsv"
}

// --- Process defaults (development / demo) ---------------------------------
process {
  executor = 'local'
  errorStrategy = 'terminate'
}
