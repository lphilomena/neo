/*
 * NeoAg Nextflow — Root Configuration
 *
 * Auto-loaded by Nextflow (no -c needed). Workflow-specific overrides belong
 * in conf/<workflow>.config or passed via -c at invocation time.
 *
 * Profiles (activate with -profile <name>):
 *   standard      Local executor (default)
 *   slurm         SLURM HPC cluster
 *   sge           SGE/UGE HPC cluster
 *   conda         Conda environment runtime
 *   docker        Docker container runtime (per-process opt-in)
 */

// --- Default parameters ----------------------------------------------------
params {
  outdir = 'results'
  strict_mode = false
  trace = false
}

// --- Environment defaults --------------------------------------------------
// Container and conda engines are enabled per-profile (not globally).
// Activate with: -profile docker  or  -profile conda
// Docker execution of individual tools within neoag-v03 processes is
// controlled by NEOAG_RUNNER_MODE (see env {} block below), not by profiles.

conda {
  cacheDir = "${launchDir}/work/.nextflow_conda"
}

// --- Executor defaults -----------------------------------------------------
process {
  executor = 'local'
  maxForks = 1
  errorStrategy = { task.exitStatus in 137..140 ? 'retry' : 'terminate' }
  maxRetries = 2
  maxErrors = '-1'
  cache = 'lenient'
  publishDir = [
    path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
    mode: 'copy',
  ]
}

// --- Resource labels -------------------------------------------------------
// Assign labels to processes for HPC/cloud scheduling:
//   label 'small'   → light I/O-bound parsing/formatting
//   label 'medium'  → moderate compute (scoring, safety)
//   label 'large'   → heavy compute (variant calling, pVAC)
//   label 'huge'    → very heavy (alignment, assembly)
process {
  withLabel: small {
    cpus = 1
    memory = 2.GB
    time = '2.h'
  }
  withLabel: medium {
    cpus = 4
    memory = 8.GB
    time = '8.h'
  }
  withLabel: large {
    cpus = 8
    memory = 32.GB
    time = '24.h'
  }
  withLabel: huge {
    cpus = 16
    memory = 64.GB
    time = '72.h'
  }
}

// --- Timeline & reporting --------------------------------------------------
timeline {
  enabled = true
  file = "${params.outdir}/pipeline_info/timeline.html"
}

report {
  enabled = true
  file = "${params.outdir}/pipeline_info/report.html"
}

trace {
  enabled = true
  file = "${params.outdir}/pipeline_info/trace.txt"
}

// Profiles --------------------------------------------------------------

profiles {

  // Standard: local execution (development / demo)
  standard {
    process.executor = 'local'
    process.errorStrategy = 'terminate'
  }

  // SLURM HPC cluster
  slurm {
    process.executor = 'slurm'
    process.queue = { task.label == 'huge' ? 'himem' : 'normal' }
    process.clusterOptions = { task.label == 'large' || task.label == 'huge' ? '--exclusive' : '--share' }
    executor {
      name = 'slurm'
      queueSize = 100
      pollInterval = '30 sec'
    }
  }

  // SGE / UGE HPC cluster
  sge {
    process.executor = 'sge'
    process.queue = { task.label == 'huge' ? 'himem.q' : 'all.q' }
    executor {
      name = 'sge'
      queueSize = 100
      pollInterval = '30 sec'
    }
  }

  // Docker container runtime — per-process opt-in.
  // Processes with a `container` directive run inside their image;
  // processes without run natively, relying on tools.env.sh / conda.
  // No global process.container is set — each module opts in independently.
  docker {
    docker {
      enabled = true
      runOptions = '-u \$(id -u):\$(id -g)'
    }
  }

  // Conda environment runtime (uses project's existing conda patterns)
  conda {
    process.conda = "${launchDir}/conda/env.neoag-tools.yml"
    conda {
      enabled = true
      cacheDir = "${launchDir}/work/.nextflow_conda"
    }
  }

}

// --- NXF_HOME is set by bin/neoag-nextflow launcher, not here --------------
// The launcher exports: NXF_HOME="${NXF_HOME:-$ROOT/work/.nextflow_home}"

// --- Propagate run-full environment variables to all processes --------------
// neoag-v03 run-upstream / run-v03 read NEOAG_RUNNER_MODE at runtime to
// decide whether to use Docker or Conda for tool execution.  Pass it through
// so Nextflow processes behave the same as the Python CLI.
//
// PATH fix: tools.env.sh puts neoag-tools/bin before neoag-vep/bin, causing
// /usr/bin/env perl to resolve to neoag-tools Perl which lacks DBI.pm.
// Prepend neoag-vep/bin (same fix as tests/run_demo/run_demo.sh line 10).
env {
  NEOAG_RUNNER_MODE = System.getenv('NEOAG_RUNNER_MODE') ?: 'conda'
  // Ensure /usr/bin (docker, etc.) is available in process environments.
  // Nextflow may trim PATH for reproducibility; restore essential system dirs.
  // Append (not prepend) so conda env binaries (e.g. perl 5.32) take priority
  // over system binaries (perl 5.34) for correct VEP module resolution.
  PATH = "${System.getenv('PATH')}:/usr/bin:/usr/local/bin"
  // Fix VEP Perl module resolution when conda base is accessed via symlink.
  // Compiled Perl modules embed the physical path; Perl @INC can't resolve
  // them through the symlink.  Point PERL5LIB to the canonical location.
  // VEP needs both ensembl-vep Perl modules and BioPerl from site_perl.
  PERL5LIB = { def base = new File(System.getenv('NEOAG_CONDA_BASE') ?: '/home/wb/apps/miniforge3').canonicalPath + '/envs/' + (System.getenv('NEOAG_VEP_ENV') ?: 'neoag-vep'); return "${base}/share/ensembl-vep-115.2-1:${base}/lib/perl5/site_perl" + (System.getenv('PERL5LIB') ? ":${System.getenv('PERL5LIB')}" : '') }()
}
